---
import Base from '../../layouts/Base.astro';
import { getAllPosts } from '../../posts.js';

const allPosts = await getAllPosts();
const tagMap: Record<string, number> = {};
for (const post of allPosts)
  for (const tag of post.data.tags ?? [])
    tagMap[tag] = (tagMap[tag] ?? 0) + 1;

const tags = Object.entries(tagMap).sort(([a], [b]) => a.localeCompare(b));
---

<Base title="All tags">
  <h1>Tags</h1>
  <ul class="tag-index">
    {tags.map(([tag, count]) => (
      <li>
        <a href={`/tags/${tag}/`} class="tag-pill">#{tag}</a>
        <span class="tag-count">{count} {count === 1 ? 'post' : 'posts'}</span>
      </li>
    ))}
  </ul>
</Base>

<style>
  .tag-index {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .tag-index li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .tag-count {
    font-family: var(--sans);
    font-size: 0.8125rem;
    color: var(--muted);
  }
</style>
