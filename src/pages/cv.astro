---
// Curriculum page. Placeholder Education / Experience / Skills sections,
// styled with the existing ul.posts rows so no new CSS is needed.
import Base from '../layouts/Base.astro';
---

<Base title="CV">
  <h1>CV</h1>
  <p><a href="/cv.pdf">Download PDF</a></p>

  <h2>Education</h2>
  <ul class="posts">
    <li>Placeholder degree — Institution — Year</li>
  </ul>

  <h2>Experience</h2>
  <ul class="posts">
    <li>Placeholder role — Company — Dates</li>
  </ul>

  <h2>Skills</h2>
  <ul class="posts">
    <li>Placeholder skill area</li>
  </ul>
</Base>
