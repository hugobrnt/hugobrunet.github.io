---
// One file builds every section's listing page (/blog/, /readings/, …),
// one per folder under src/content/.
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import { getCollection } from 'astro:content';
import { sectionNames, titleCase } from '../../sections.js';

export function getStaticPaths() {
  return sectionNames.map((section) => ({ params: { section } }));
}

const { section } = Astro.params;
const heading = titleCase(section);

const posts = (await getCollection(section)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title={heading}>
  <h1>{heading}</h1>
  <PostList posts={posts} />
</Base>
