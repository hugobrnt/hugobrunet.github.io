---
// The one HTML shell for the whole site. Every page passes in a title
// (and optionally a description) and its content via <slot />.
import '../styles/global.css';
import PostList from '../components/PostList.astro';
import { sectionNames } from '../sections.js';
import { getAllPosts } from '../posts.js';

const { title, description = 'Personal site: projects, essays, and CS notes.' } = Astro.props;

// Navbar: `about`, then one link per content folder, then `curriculum`.
const sections = [
  { href: '/', label: 'about' },
  ...sectionNames.map((name) => ({ href: `/${name}/`, label: name })),
  { href: '/cv', label: 'curriculum' },
];

// The five most recent posts across every section, for the Recent sidebar.
const allPosts = await getAllPosts();
const allCategories = [...new Set(allPosts.flatMap(p => p.data.categories ?? []))].sort();

// Highlight the nav link of the section we're currently in.
const current = Astro.url.pathname;

// Filter Recent: hide the whole section on listing pages, hide only the
// current post on post pages, so Recent always suggests something new.
const urlParts = current.split('/').filter(Boolean);
const currentSection = sectionNames.find(name => name === urlParts[0]);
const isPostPage = currentSection != null && urlParts.length >= 2;
const currentSlug = isPostPage ? urlParts[1] : null;

const recent = allPosts
  .filter(p => {
    if (!currentSection) return true;
    if (isPostPage) return !(p.collection === currentSection && p.id === currentSlug);
    return p.collection !== currentSection;
  })
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Set the theme before paint to avoid a flash of the wrong theme.
      const stored = localStorage.getItem('theme');
      const theme = stored || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/public/icon.jpg" type="jpg" />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <!-- Medium-style fonts: Source Serif 4 (body) + Inter (UI) -->
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,700;1,8..60,400&display=swap" rel="stylesheet" />
	<!-- KaTeX stylesheet: only needed so $math$ renders nicely -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="home">Hugo Brunet's Log Book</a>
        <div class="nav-right">
        {sections.map((s) => (
          <a
            href={s.href}
            aria-current={current === s.href || (s.href !== '/' && current.startsWith(s.href)) ? 'page' : undefined}
          >{s.label}</a>
        ))}
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle color theme">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
          </svg>
        </button>
        </div>
      </nav>
    </header>

    <div class="page">
      <main>
        <slot />
      </main>
      <div class="sidebar">
        {recent.length > 0 && (
          <aside class="recent">
            <h2>Recents</h2>
            <PostList posts={recent} showSection />
          </aside>
        )}
        {allCategories.length > 0 && (
          <aside class="categories-sidebar">
            <h2><a href="/categories/">Categories</a></h2>
            <div class="category-cloud">
              {allCategories.map(cat => <a href={`/categories/${cat}/`} class="category-pill">#{cat}</a>)}
            </div>
          </aside>
        )}
      </div>
    </div>

    <footer>
      <a href="https://github.com/hugobrnt">github</a>
      <a href="https://www.linkedin.com/in/hugo-brunet-pro">linkedin</a>
      <span>© {new Date().getFullYear()}</span>
    </footer>

    <script>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>

    <script>
      // Wrap each code block and add a copy-to-clipboard button.
      document.querySelectorAll('main pre').forEach((pre) => {
        const wrapper = document.createElement('div');
        wrapper.className = 'code-block';
        pre.replaceWith(wrapper);
        wrapper.appendChild(pre);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(pre.innerText.replace(/\n$/, ''));
            btn.textContent = 'Copied';
          } catch {
            btn.textContent = 'Error';
          }
          setTimeout(() => (btn.textContent = 'Copy'), 1500);
        });
        wrapper.appendChild(btn);
      });
    </script>
  </body>
</html>
