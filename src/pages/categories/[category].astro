---
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import { getAllPosts } from '../../posts.js';

export async function getStaticPaths() {
  const allPosts = await getAllPosts();
  const categoryMap: Record<string, typeof allPosts> = {};
  for (const post of allPosts)
    for (const cat of post.data.categories ?? []) {
      if (!categoryMap[cat]) categoryMap[cat] = [];
      categoryMap[cat].push(post);
    }
  return Object.entries(categoryMap).map(([category, posts]) => ({ params: { category }, props: { posts } }));
}

const { category } = Astro.params;
const { posts } = Astro.props;
---

<Base title={`#${category}`}>
  <h1>#{category}</h1>
  <p class="meta">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  <PostList posts={posts} showSection />
</Base>
