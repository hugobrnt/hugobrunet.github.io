---
// One file renders every individual post. getStaticPaths lists every
// post in every section, and Astro builds one HTML page for each,
// at /<section>/<slug>/.
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { sectionNames } from '../../sections.js';

export async function getStaticPaths() {
  const paths = [];
  for (const section of sectionNames) {
    for (const post of await getCollection(section)) {
      paths.push({ params: { section, slug: post.id }, props: { post } });
    }
  }
  return paths;
}

const { post } = Astro.props;
const { Content } = await render(post); // compiles the Markdown body
const date = post.data.date.toISOString().slice(0, 10);
---

<Base title={post.data.title} description={post.data.description}>
  <a href={`/${post.collection}/`} class="back">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M9.793 2.232a.75.75 0 0 1-.025 1.06L3.622 9.25h14.628a.75.75 0 0 1 0 1.5H3.622l6.146 5.958a.75.75 0 1 1-1.036 1.085l-7.5-7.25a.75.75 0 0 1 0-1.085l7.5-7.25a.75.75 0 0 1 1.06.025Z" clip-rule="evenodd" />
    </svg>
    {post.collection}
  </a>
  <h1>{post.data.title}</h1>
  <p class="meta">{date} · {post.collection}</p>
  <Content />
</Base>
