---
// Renders a list of posts as "date  title" rows.
// Each post links to /<section>/<slug>/ — the section is the
// collection the post belongs to (blog, essays or projects).
const { posts } = Astro.props;

const fmt = (d) => d.toISOString().slice(0, 10); // 2026-06-11
---

<ul class="posts">
  {posts.map((post) => (
    <li>
      <time datetime={fmt(post.data.date)}>{fmt(post.data.date)}</time>
      <a href={`/${post.collection}/${post.id}/`}>{post.data.title}</a>
    </li>
  ))}
</ul>
